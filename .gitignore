# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
#/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# hardhat (used only for compile + verify; never deploys)
/artifacts
/cache
/typechain-types

# standalone solc cache (downloaded by tools/compile.js)
/tools/.cache

# local audit-indexer config (RPC keys, custom block ranges, etc.).
# tools/audit-config.local.example.js IS committed as a template.
/tools/audit-config.local.js
/.env

# Ponder indexer — local-only. The audit deliverable is the JSON the
# snapshot script writes into build/audit/, not the indexer source.
# Skip the whole tree.
/tools/ponder/

# Local dev artifacts from contract bytecode extraction.
/tools/.vault-bytecode.json
/tools/.vault-bytecode-strs.txt
